{
  "name": "csv-powertool-transformer",
  "version": "1.0.0",
  "description": "CSV Powertool Transformer — Gestion de bases TCG et traitement CSV",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder --win --mac --linux"
  },
  "build": {
    "appId": "fr.le-tengu.csv-powertool-transformer",
    "productName": "CSV Powertool Transformer",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "app/**/*",
      "!app/database/**/*"
    ],
    "extraResources": [
      {
        "from": "app/database",
        "to": "database",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": ["nsis", "portable"],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "build/icon.png",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${name}-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "${name}-${version}.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
